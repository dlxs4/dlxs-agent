{
  "name": "Shift Host Node",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {
        "version": "latest"
    }
  },
  "forwardPorts":[
    4000,
    3000, 3001, 3002, 3003, 3004, 3005, 3006, 3007, 3008, 3009,
    3010, 3011, 3012, 3013, 3014, 3015, 3016, 3017, 3018, 3019,
    3020, 3021, 3022, 3023, 3024, 3025, 3026, 3027, 3028, 3029,
    3030, 3031, 3032, 3033, 3034, 3035, 3036, 3037, 3038, 3039,
    3040, 3041, 3042, 3043, 3044, 3045, 3046, 3047, 3048, 3049,
    3050, 3051, 3052, 3053, 3054, 3055, 3056, 3057, 3058, 3059,
    3060, 3061, 3062, 3063, 3064, 3065, 3066, 3067, 3068, 3069,
    3070, 3071, 3072, 3073, 3074, 3075, 3076, 3077, 3078, 3079,
    3080, 3081, 3082, 3083, 3084, 3085, 3086, 3087, 3088, 3089,
    3090, 3091, 3092, 3093, 3094, 3095, 3096, 3097, 3098, 3099
  ],
  "portsAttributes": {
    "4000": { "label": "Shift Agent", "visibility": "public" },
    "3001-3010": { "label": "User Payload", "visibility": "public" }
  },
  "postCreateCommand": "until curl -fsSL \"$GATEWAY_URL/api/internal/download-agent\" -o agent.js; do echo 'Waiting for Gateway...'; sleep 5; done && npm install -g pm2",
  "postStartCommand": "bash -c 'while ! docker info > /dev/null 2>&1; do sleep 2; done; pm2 start /workspaces/dlxs-agent/agent.js --name shift-agent'"
}
